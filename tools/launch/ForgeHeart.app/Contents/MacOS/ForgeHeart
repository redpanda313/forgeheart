#!/bin/bash
# ForgeHeart desktop launcher — starts Vite dev server and opens the game.

set -euo pipefail

# Finder-launched apps get a minimal PATH
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# Project root (this app lives in tools/launch/ForgeHeart.app or Desktop copy)
# Prefer env override, then sibling of .app if in tools/launch, else known path.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_BUNDLE="$(cd "$SCRIPT_DIR/../.." && pwd)"

# If Desktop copy, resolve project via marker file next to app or embedded config
CONFIG="$APP_BUNDLE/Contents/Resources/project-path.txt"
if [[ -f "$CONFIG" ]]; then
  PROJECT="$(cat "$CONFIG" | tr -d '\r\n')"
else
  # tools/launch/ForgeHeart.app → ../../../
  CANDIDATE="$(cd "$APP_BUNDLE/../.." 2>/dev/null && pwd)"
  if [[ -f "$CANDIDATE/package.json" ]]; then
    PROJECT="$CANDIDATE"
  else
    PROJECT="/Users/lotusmountain/trump-doom"
  fi
fi

PORT=5180
URL="http://localhost:${PORT}/"
LOG="$HOME/Library/Logs/ForgeHeart-launcher.log"
mkdir -p "$(dirname "$LOG")"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"; }

alert() {
  osascript -e "display alert \"ForgeHeart\" message \"$1\" as critical" >/dev/null 2>&1 || true
}

notify() {
  osascript -e "display notification \"$1\" with title \"ForgeHeart\"" >/dev/null 2>&1 || true
}

if [[ ! -d "$PROJECT" || ! -f "$PROJECT/package.json" ]]; then
  alert "Could not find the game project at:\n$PROJECT"
  exit 1
fi

if ! command -v node >/dev/null 2>&1 || ! command -v npm >/dev/null 2>&1; then
  alert "Node.js / npm not found. Install Node, then try again."
  exit 1
fi

cd "$PROJECT"
log "Project: $PROJECT"

if [[ ! -d node_modules ]]; then
  notify "Installing dependencies…"
  log "npm install…"
  npm install >>"$LOG" 2>&1 || {
    alert "npm install failed. See ~/Library/Logs/ForgeHeart-launcher.log"
    exit 1
  }
fi

is_up() {
  curl -sf -o /dev/null --max-time 1 "$URL" 2>/dev/null
}

if is_up; then
  log "Server already running on $PORT"
  notify "Opening ForgeHeart…"
  open "$URL"
  exit 0
fi

# Start Vite in background (detached from app so it keeps running)
notify "Starting ForgeHeart server…"
log "Starting npm run dev on port $PORT"

# Use nohup so server survives after this script exits
nohup npm run dev >>"$LOG" 2>&1 &
echo $! > "$HOME/Library/Logs/ForgeHeart-dev.pid"

# Wait for server
for i in $(seq 1 60); do
  if is_up; then
    log "Server ready after ${i}s"
    notify "ForgeHeart is ready"
    open "$URL"
    exit 0
  fi
  sleep 0.5
done

alert "Server did not start in time. Check ~/Library/Logs/ForgeHeart-launcher.log"
exit 1
